##############################################
# Python
##############################################

__pycache__/
*.py[cod]
*$py.class

##############################################
# Virtual Environment
##############################################

venv/
.env
.env.*

##############################################
# IDE
##############################################

.vscode/
.idea/

##############################################
# OS Files
##############################################

.DS_Store
Thumbs.db

##############################################
# Logs
##############################################

logs/*
!logs/.gitkeep
*.log

##############################################
# Generated Reports
##############################################

reports/generated/*
!reports/generated/.gitkeep

##############################################
# Generated Evidence
##############################################

evidence/*
!evidence/.gitkeep

##############################################
# Baselines generated during execution
##############################################

baseline/*
!baseline/.gitkeep

##############################################
# Runtime cache
##############################################
*.db
*.sqlite
*.sqlite3

##############################################
# PDF Reports
##############################################

*.pdf
reports/generated/*.pdf

##############################################
# Temporary
##############################################

*.tmp
*.bak
*.swp
##############################################
# Runtime flags
##############################################

scan_complete.flag